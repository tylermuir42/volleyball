# Database Configuration
# Copy this to .env and fill in your values

# PostgreSQL Connection (Local Development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=tournament_db

# For AWS RDS (uncomment and update when ready)
# DB_HOST=tournament-db.xxxxx.us-west-2.rds.amazonaws.com
# DB_USER=admin
# DB_PASSWORD=your_rds_password
# DB_NAME=tournament_db

# Backend Server
NODE_ENV=development
PORT=5000

# AWS Configuration (for EventBridge, Phase 3+)
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# EventBridge
# EVENTBRIDGE_BUS_NAME=tournament-events

# Database Pool
DB_POOL_SIZE=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000
